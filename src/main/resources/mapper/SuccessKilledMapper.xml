<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.seckillzc.mapper.SuccessKilledMapper">

    <!--
      插入秒杀明细。INSERT IGNORE 在联合主键 (seckill_id, user_phone) 冲突时跳过，
      返回影响行数：1=插入成功，0=该用户已秒杀过（冲突被忽略）。
      state 由调用方显式传入；created_at 由数据库默认值填充（当前时间）。
      说明：MyBatis-Plus 自带 insert() 不生成 IGNORE，故自定义此方法。
    -->
    <insert id="insertSuccessKilled">
        INSERT IGNORE INTO success_killed (seckill_id, user_phone, state)
        VALUES (#{seckillId}, #{userPhone}, #{state})
    </insert>

</mapper>
